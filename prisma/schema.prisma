model crm_Job_Documents {
  id              String          @id @default(uuid()) @db.Uuid
  job_id          String          @db.Uuid
  document_id     String?         @db.Uuid   // pointer to Documents model (file storage)
  name            String          // "Contingency Contract", "Original Claim Summary"
  doc_type        String?         // required, attachment
  is_required     Boolean         @default(false)
  file_url        String?         // direct URL if not using Documents model
  file_name       String?
  file_size       Int?
  mime_type       String?
  uploaded_by     String?         @db.Uuid
  uploaded_at     DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?       @updatedAt
  deletedAt       DateTime?
  deletedBy       String?         @db.Uuid

  job             crm_Opportunities @relation(fields: [job_id], references: [id])
  document        Documents?      @relation(fields: [document_id], references: [id])
  uploader        Users?          @relation("job_doc_uploaded_by", fields: [uploaded_by], references: [id])

  @@index([job_id])
  @@index([document_id])
  @@index([doc_type])
  @@index([is_required])
  @@index([deletedAt])
}

model crm_Payments {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  amount          Decimal             @db.Decimal(12, 2)
  date            DateTime
  method          crm_Payment_Method?
  notes           String?
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])

  @@index([job_id])
  @@index([date])
  @@index([deletedAt])
}

enum crm_Payment_Method {
  CHECK
  ACH
  CREDIT_CARD
  CASH
  INSURANCE
  OTHER
}

model crm_Estimates {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  estimate_number String?             // auto: EST-{job_number}-{seq}
  title           String?             // "Deposit Estimate", "Full Scope Estimate"
  status          crm_Estimate_Status @default(DRAFT)
  subtotal        Decimal?            @db.Decimal(12, 2)
  tax             Decimal?            @db.Decimal(12, 2)
  total           Decimal?            @db.Decimal(12, 2)
  sent_at         DateTime?
  accepted_at     DateTime?
  rejected_at     DateTime?
  expires_at      DateTime?
  notes           String?
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])
  created_by_user Users?              @relation("estimate_created_by", fields: [createdBy], references: [id])
  line_items      crm_Estimate_Line_Items[]

  @@index([job_id])
  @@index([status])
  @@index([deletedAt])
}

enum crm_Estimate_Status {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model crm_Estimate_Line_Items {
  id              String          @id @default(uuid()) @db.Uuid
  estimate_id     String          @db.Uuid
  description     String
  category        String?         // labor, materials, equipment, other
  quantity        Decimal?        @db.Decimal(10, 2)
  unit            String?         // sq, lf, each, hour, flat
  unit_price      Decimal?        @db.Decimal(12, 2)
  amount          Decimal?        @db.Decimal(12, 2)
  sort_order      Int             @default(0)
  pricebook_item_id String?       @db.Uuid

  estimate        crm_Estimates   @relation(fields: [estimate_id], references: [id], onDelete: Cascade)

  @@index([estimate_id])
}

model crm_Invoices {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  invoice_number  String?             // auto: INV-{job_number}-{seq}
  title           String?             // "Deposit Invoice", "Final Invoice — Deductible"
  status          crm_Invoice_Status  @default(DRAFT)
  subtotal        Decimal?            @db.Decimal(12, 2)
  tax             Decimal?            @db.Decimal(12, 2)
  total           Decimal             @db.Decimal(12, 2)
  amount_paid     Decimal?            @db.Decimal(12, 2) @default(0)
  balance_due     Decimal?            @db.Decimal(12, 2)
  issued_at       DateTime?
  due_date        DateTime?
  paid_at         DateTime?
  notes           String?
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])
  created_by_user Users?              @relation("invoice_created_by", fields: [createdBy], references: [id])
  customer_payments crm_Customer_Payments[]

  @@index([job_id])
  @@index([status])
  @@index([due_date])
  @@index([deletedAt])
}

enum crm_Invoice_Status {
  DRAFT
  SENT
  OUTSTANDING
  PAID
  PARTIAL
  VOID
}

model crm_Credit_Notes {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  credit_number   String?             // auto: CN-{job_number}-{seq}
  reason          String?
  amount          Decimal             @db.Decimal(12, 2)
  status          String              @default("applied") // applied, pending, void
  applied_to_invoice String?          // reference
  notes           String?
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])

  @@index([job_id])
  @@index([deletedAt])
}

model crm_Customer_Payments {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  invoice_id      String?             @db.Uuid
  amount          Decimal             @db.Decimal(12, 2)
  date            DateTime
  method          crm_Payment_Method?
  reference       String?             // check number, transaction ID
  payer_name      String?             // "State Farm", "Mike Arvizu"
  notes           String?
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])
  invoice         crm_Invoices?       @relation(fields: [invoice_id], references: [id])

  @@index([job_id])
  @@index([invoice_id])
  @@index([date])
  @@index([deletedAt])
}

model crm_Stage_Transitions {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  from_stage_id   String?             @db.Uuid
  to_stage_id     String              @db.Uuid
  from_stage_name String?
  to_stage_name   String
  form_data       Json?               @db.JsonB   // structured data captured during transition
  transitioned_by String?             @db.Uuid
  transitioned_at DateTime            @default(now())

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])
  user            Users?              @relation(fields: [transitioned_by], references: [id])

  @@index([job_id])
  @@index([to_stage_id])
  @@index([transitioned_at])
  @@index([transitioned_by])
  @@index([job_id, transitioned_at])
}

model crm_Purchase_Orders {
  id              String                @id @default(uuid()) @db.Uuid
  job_id          String                @db.Uuid
  po_number       String?               // auto-generated: PO-{job_number}-{seq}
  vendor_id       String?               @db.Uuid
  vendor_name     String                // denormalized for display
  description     String?
  category        String?               // labor, materials, haul-off, equipment, other
  status          crm_PO_Status         @default(DRAFT)
  amount          Decimal?              @db.Decimal(12, 2)
  scheduled_date  DateTime?             // delivery or work date
  completed_date  DateTime?
  notes           String?
  createdBy       String?               @db.Uuid
  createdAt       DateTime              @default(now())
  updatedAt       DateTime?             @updatedAt
  deletedAt       DateTime?
  deletedBy       String?               @db.Uuid

  job             crm_Opportunities     @relation(fields: [job_id], references: [id])
  vendor          crm_Vendors?          @relation("po_vendor", fields: [vendor_id], references: [id])
  created_by_user Users?                @relation("po_created_by", fields: [createdBy], references: [id])
  bills           crm_Bills[]
  vendor_credits  crm_Vendor_Credits[]
  tasks           crm_Job_Tasks[]

  @@index([job_id])
  @@index([status])
  @@index([vendor_name])
  @@index([scheduled_date])
  @@index([job_id, status])
  @@index([deletedAt])
}

enum crm_PO_Status {
  DRAFT
  ORDERED
  DISPATCHED
  RECEIVED
  COMPLETED
  CANCELLED
}

model crm_Bills {
  id                String              @id @default(uuid()) @db.Uuid
  job_id            String              @db.Uuid
  purchase_order_id String?             @db.Uuid
  vendor_id         String?             @db.Uuid
  vendor_name       String              // denormalized for display
  description       String?
  amount            Decimal             @db.Decimal(12, 2)
  status            crm_Bill_Status     @default(PENDING)
  due_date          DateTime?
  paid_date         DateTime?
  notes             String?
  createdBy         String?             @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime?           @updatedAt
  deletedAt         DateTime?
  deletedBy         String?             @db.Uuid

  job               crm_Opportunities   @relation(fields: [job_id], references: [id])
  purchase_order    crm_Purchase_Orders? @relation(fields: [purchase_order_id], references: [id])
  vendor            crm_Vendors?        @relation("bill_vendor", fields: [vendor_id], references: [id])

  @@index([job_id])
  @@index([purchase_order_id])
  @@index([status])
  @@index([deletedAt])
}

enum crm_Bill_Status {
  PENDING
  APPROVED
  PAID
  VOID
}

model crm_Expenses {
  id              String              @id @default(uuid()) @db.Uuid
  job_id          String              @db.Uuid
  description     String
  amount          Decimal             @db.Decimal(12, 2)
  date            DateTime
  payment_method  String?             // "Visa ••4821", "Amex ••1190", etc.
  submitted_by    String?             @db.Uuid
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  job             crm_Opportunities   @relation(fields: [job_id], references: [id])
  submitted_user  Users?              @relation("expense_submitted_by", fields: [submitted_by], references: [id])

  @@index([job_id])
  @@index([date])
  @@index([deletedAt])
}

model crm_Vendor_Credits {
  id                String              @id @default(uuid()) @db.Uuid
  job_id            String              @db.Uuid
  purchase_order_id String?             @db.Uuid
  vendor_name       String
  description       String?
  amount            Decimal             @db.Decimal(12, 2)
  applied_to_bill   String?             // reference to bill it was applied against
  status            String              @default("applied") // applied, pending
  createdAt         DateTime            @default(now())
  updatedAt         DateTime?           @updatedAt
  deletedAt         DateTime?
  deletedBy         String?             @db.Uuid

  job               crm_Opportunities   @relation(fields: [job_id], references: [id])
  purchase_order    crm_Purchase_Orders? @relation(fields: [purchase_order_id], references: [id])

  @@index([job_id])
  @@index([purchase_order_id])
  @@index([deletedAt])
}

model crm_Vendors {
  id              String              @id @default(uuid()) @db.Uuid
  name            String
  type            String?             // subcontractor, supplier, equipment, other
  contact_name    String?
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zip             String?
  notes           String?
  is_active       Boolean             @default(true)
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  purchase_orders crm_Purchase_Orders[] @relation("po_vendor")
  bills           crm_Bills[]           @relation("bill_vendor")

  @@index([name])
  @@index([type])
  @@index([is_active])
  @@index([deletedAt])
}

model crm_PriceBook_Items {
  id              String              @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String?             // labor, materials, equipment, service, other
  unit            String?             // sq, lf, each, hour, flat
  unit_cost       Decimal?            @db.Decimal(12, 2)
  unit_price      Decimal?            @db.Decimal(12, 2)  // default sell price
  is_active       Boolean             @default(true)
  createdBy       String?             @db.Uuid
  createdAt       DateTime            @default(now())
  updatedAt       DateTime?           @updatedAt
  deletedAt       DateTime?
  deletedBy       String?             @db.Uuid

  @@index([name])
  @@index([category])
  @@index([is_active])
  @@index([deletedAt])
}

model crm_Job_Tasks {
  id                String              @id @default(uuid()) @db.Uuid
  job_id            String              @db.Uuid
  title             String
  description       String?
  status            crm_Job_Task_Status @default(OPEN)
  priority          crm_Job_Task_Priority @default(NORMAL)
  due_date          DateTime?
  completed_at      DateTime?
  assigned_to       String?             @db.Uuid
  appointment_id    String?             @db.Uuid   // optional: task happens during this appointment
  purchase_order_id String?             @db.Uuid   // optional: task relates to a PO
  createdBy         String?             @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime?           @updatedAt
  deletedAt         DateTime?
  deletedBy         String?             @db.Uuid

  job               crm_Opportunities   @relation(fields: [job_id], references: [id])
  assigned_user     Users?              @relation("job_task_assigned_to", fields: [assigned_to], references: [id])
  appointment       crm_Appointments?   @relation(fields: [appointment_id], references: [id])
  purchase_order    crm_Purchase_Orders? @relation(fields: [purchase_order_id], references: [id])

  @@index([job_id])
  @@index([assigned_to])
  @@index([appointment_id])
  @@index([purchase_order_id])
  @@index([status])
  @@index([due_date])
  @@index([job_id, status])
  @@index([deletedAt])
}

enum crm_Job_Task_Status {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum crm_Job_Task_Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model crm_Appointments {
  id              String                 @id @default(uuid()) @db.Uuid
  job_id          String                 @db.Uuid
  title           String
  type            crm_Appointment_Type
  status          crm_Appointment_Status @default(SCHEDULED)
  start_date      DateTime
  end_date        DateTime?
  all_day         Boolean                @default(false)
  assigned_to     String                 @db.Uuid   // primary person/crew lead
  crew_name       String?                // "Peak Roofing Crew", etc.
  notes           String?
  createdBy       String?                @db.Uuid
  createdAt       DateTime               @default(now())
  updatedAt       DateTime?              @updatedAt
  deletedAt       DateTime?
  deletedBy       String?                @db.Uuid

  job             crm_Opportunities      @relation(fields: [job_id], references: [id])
  assigned_user   Users                  @relation("appointment_assigned_to", fields: [assigned_to], references: [id])
  created_by_user Users?                 @relation("appointment_created_by", fields: [createdBy], references: [id])
  tasks           crm_Job_Tasks[]

  @@index([job_id])
  @@index([assigned_to])
  @@index([start_date])
  @@index([status])
  @@index([type])
  @@index([job_id, start_date])
  @@index([deletedAt])
}

enum crm_Appointment_Type {
  INSPECTION
  ADJUSTER
  SALES_VISIT
  PRE_CONSTRUCTION
  BUILD
  DELIVERY
  FINAL_WALKTHROUGH
  WARRANTY
  OTHER
}

enum crm_Appointment_Status {
  SCHEDULED
  DISPATCHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// JUNCTION TABLES FOR MANY-TO-MANY RELATIONSHIPS
// ============================================

// Documents junction tables (6 tables)
model DocumentsToOpportunities {
  document_id    String @db.Uuid
  opportunity_id String @db.Uuid

  document    Documents         @relation(fields: [document_id], references: [id], onDelete: Cascade)
  opportunity crm_Opportunities @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  @@id([document_id, opportunity_id])
  @@index([document_id])
  @@index([opportunity_id])
}

model DocumentsToContacts {
  document_id String @db.Uuid
  contact_id  String @db.Uuid

  document Documents    @relation(fields: [document_id], references: [id], onDelete: Cascade)
  contact  crm_Contacts @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@id([document_id, contact_id])
  @@index([document_id])
  @@index([contact_id])
}

model DocumentsToTasks {
  document_id String @db.Uuid
  task_id     String @db.Uuid

  document Documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  task     Tasks     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@id([document_id, task_id])
  @@index([document_id])
  @@index([task_id])
}

model DocumentsToCrmAccountsTasks {
  document_id          String @db.Uuid
  crm_accounts_task_id String @db.Uuid

  document          Documents          @relation(fields: [document_id], references: [id], onDelete: Cascade)
  crm_accounts_task crm_Accounts_Tasks @relation(fields: [crm_accounts_task_id], references: [id], onDelete: Cascade)

  @@id([document_id, crm_accounts_task_id])
  @@index([document_id])
  @@index([crm_accounts_task_id])
}

model DocumentsToLeads {
  document_id String @db.Uuid
  lead_id     String @db.Uuid

  document Documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  lead     crm_Leads @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@id([document_id, lead_id])
  @@index([document_id])
  @@index([lead_id])
}

model DocumentsToAccounts {
  document_id String @db.Uuid
  account_id  String @db.Uuid

  document Documents    @relation(fields: [document_id], references: [id], onDelete: Cascade)
  account  crm_Accounts @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@id([document_id, account_id])
  @@index([document_id])
  @@index([account_id])
}

model DocumentsToInvoices {
  document_id String @db.Uuid
  invoice_id  String @db.Uuid

  document Documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  invoice  Invoices  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@id([document_id, invoice_id])
  @@index([document_id])
  @@index([invoice_id])
}

// Watchers junction tables (2 tables)
model AccountWatchers {
  account_id String @db.Uuid
  user_id    String @db.Uuid

  account crm_Accounts @relation(fields: [account_id], references: [id], onDelete: Cascade)
  user    Users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([account_id, user_id])
  @@index([account_id])
  @@index([user_id])
}

model BoardWatchers {
  board_id String @db.Uuid
  user_id  String @db.Uuid

  board Boards @relation(fields: [board_id], references: [id], onDelete: Cascade)
  user  Users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([board_id, user_id])
  @@index([board_id])
  @@index([user_id])
}

// Contacts to Opportunities junction table
model ContactsToOpportunities {
  contact_id     String @db.Uuid
  opportunity_id String @db.Uuid

  contact     crm_Contacts      @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  opportunity crm_Opportunities @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  @@id([contact_id, opportunity_id])
  @@index([contact_id])
  @@index([opportunity_id])
}

// ============================================
// CRM TARGETS FEATURE
// ============================================

model crm_Targets {
  id               String    @id @default(uuid()) @db.Uuid
  first_name       String?
  last_name        String
  email            String?
  mobile_phone     String?
  office_phone     String?
  company          String?
  company_website  String?
  personal_website String?
  position         String?
  social_x         String?
  social_linkedin  String?
  social_instagram String?
  social_facebook  String?
  status           Boolean   @default(true)
  tags             String[]
  notes            String[]
  created_by       String?   @db.Uuid
  created_on       DateTime? @default(now())
  updatedAt        DateTime? @updatedAt
  updatedBy        String?   @db.Uuid

  // Extended contact fields
  personal_email   String?
  company_email    String?
  company_phone    String?
  city             String?
  country          String?
  industry         String?
  employees        String?
  description      String?

  // Conversion tracking
  converted_at         DateTime?
  converted_account_id String?   @db.Uuid
  converted_contact_id String?   @db.Uuid

  crate_by_user     Users?                 @relation("created_targets", fields: [created_by], references: [id])
  target_lists      TargetsToTargetLists[]
  enrichments       crm_Target_Enrichment[]
  target_contacts   crm_Target_Contact[]
  campaign_sends    crm_campaign_sends[]
  converted_account crm_Accounts?          @relation("target_converted_account", fields: [converted_account_id], references: [id], onDelete: SetNull)
  converted_contact crm_Contacts?          @relation("target_converted_contact", fields: [converted_contact_id], references: [id], onDelete: SetNull)

  @@index([created_by])
  @@index([status])
  @@index([created_on])
  @@index([converted_account_id])
  @@index([converted_contact_id])
}

model crm_TargetLists {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  status      Boolean   @default(true)
  created_by  String?   @db.Uuid
  created_on  DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  crate_by_user  Users?               @relation("created_target_lists", fields: [created_by], references: [id])
  targets        TargetsToTargetLists[]
  campaign_lists CampaignToTargetLists[]

  @@index([created_by])
  @@index([status])
}

model TargetsToTargetLists {
  target_id      String @db.Uuid
  target_list_id String @db.Uuid

  target      crm_Targets     @relation(fields: [target_id], references: [id], onDelete: Cascade)
  target_list crm_TargetLists @relation(fields: [target_list_id], references: [id], onDelete: Cascade)

  @@id([target_id, target_list_id])
  @@index([target_id])
  @@index([target_list_id])
}

// ============================================
// PGVECTOR EMBEDDING COMPANION MODELS
// ============================================

model crm_Embeddings_Accounts {
  id           String   @id @default(uuid()) @db.Uuid
  account_id   String   @unique @db.Uuid
  embedding    Unsupported("vector(1536)")
  content_hash String
  /// Must be set explicitly on upsert — @default(now()) only fires on INSERT
  embedded_at  DateTime @default(now())
  account      crm_Accounts @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@map("crm_Embeddings_Accounts")
}

model crm_Embeddings_Contacts {
  id           String   @id @default(uuid()) @db.Uuid
  contact_id   String   @unique @db.Uuid
  embedding    Unsupported("vector(1536)")
  content_hash String
  /// Must be set explicitly on upsert — @default(now()) only fires on INSERT
  embedded_at  DateTime @default(now())
  contact      crm_Contacts @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@map("crm_Embeddings_Contacts")
}

model crm_Embeddings_Leads {
  id           String   @id @default(uuid()) @db.Uuid
  lead_id      String   @unique @db.Uuid
  embedding    Unsupported("vector(1536)")
  content_hash String
  /// Must be set explicitly on upsert — @default(now()) only fires on INSERT
  embedded_at  DateTime @default(now())
  lead         crm_Leads @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@map("crm_Embeddings_Leads")
}

model crm_Embeddings_Opportunities {
  id             String   @id @default(uuid()) @db.Uuid
  opportunity_id String   @unique @db.Uuid
  embedding      Unsupported("vector(1536)")
  content_hash   String
  /// Must be set explicitly on upsert — @default(now()) only fires on INSERT
  embedded_at    DateTime @default(now())
  opportunity    crm_Opportunities @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  @@map("crm_Embeddings_Opportunities")
}

// ============================================
// API TOKENS
// ============================================

model ApiToken {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  tokenHash   String    @unique
  tokenPrefix String    @db.VarChar(8)
  userId      String    @db.Uuid
  user        Users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// ============================================
// EMAIL FEATURE
// ============================================

model EmailAccount {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  label             String
  imapHost          String
  imapPort          Int
  imapSsl           Boolean   @default(true)
  smtpHost          String
  smtpPort          Int
  smtpSsl           Boolean   @default(true)
  username          String
  passwordEncrypted String
  isActive          Boolean   @default(true)
  sentFolderName    String    @default("Sent")
  lastSyncedAt      DateTime?
  inboxLastUid      Int?
  sentLastUid       Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user   Users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[]

  @@index([userId])
  @@index([isActive])
}

enum EmailFolder {
  INBOX
  SENT
}

model Email {
  id              String      @id @default(uuid()) @db.Uuid
  emailAccountId  String      @db.Uuid
  userId          String      @db.Uuid
  rfcMessageId    String
  imapUid         Int?
  folder          EmailFolder
  subject         String?
  fromName        String?
  fromEmail       String?
  toRecipients    Json        @default("[]")
  ccRecipients    Json        @default("[]")
  bccRecipients   Json        @default("[]")
  bodyText        String?
  bodyHtml        String?
  sentAt          DateTime?
  isRead          Boolean     @default(false)
  isDeleted       Boolean     @default(false)
  updatedAt       DateTime    @updatedAt
  createdAt       DateTime    @default(now())

  account   EmailAccount     @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  user      Users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding EmailEmbedding?
  contacts  EmailsToContacts[]
  accounts  EmailsToAccounts[]

  @@unique([emailAccountId, rfcMessageId])
  @@index([userId])
  @@index([emailAccountId])
  @@index([folder])
  @@index([isDeleted])
  @@index([sentAt])
  @@index([userId, folder, isDeleted, isRead])
}

model EmailEmbedding {
  id          String   @id @default(uuid()) @db.Uuid
  emailId     String   @unique @db.Uuid
  embedding   Unsupported("vector(1536)")
  contentHash String
  embeddedAt  DateTime @default(now())

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@map("EmailEmbedding")
}

model EmailsToContacts {
  emailId   String @db.Uuid
  contactId String @db.Uuid

  email   Email        @relation(fields: [emailId], references: [id], onDelete: Cascade)
  contact crm_Contacts @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([emailId, contactId])
  @@index([emailId])
  @@index([contactId])
}

model EmailsToAccounts {
  emailId   String @db.Uuid
  accountId String @db.Uuid

  email   Email        @relation(fields: [emailId], references: [id], onDelete: Cascade)
  account crm_Accounts @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([emailId, accountId])
  @@index([emailId])
  @@index([accountId])
}
