// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model crm_Accounts {
  id                   String    @id @default(uuid()) @db.Uuid
  v                    Int       @map("__v")
  createdAt            DateTime  @default(now())
  createdBy            String?   @db.Uuid
  updatedAt            DateTime? @updatedAt
  updatedBy            String?   @db.Uuid
  annual_revenue       String?
  assigned_to          String?   @db.Uuid
  billing_city         String?
  billing_country      String?
  billing_postal_code  String?
  billing_state        String?
  billing_street       String?
  company_id           String?
  description          String?
  email                String?
  employees            String?
  fax                  String?
  industry             String?   @db.Uuid
  member_of            String?
  name                 String
  office_phone         String?
  shipping_city        String?
  shipping_country     String?
  shipping_postal_code String?
  shipping_state       String?
  shipping_street      String?
  status               String?   @default("Inactive")
  type                 String?   @default("Customer")
  vat                  String?
  website              String?
  deletedAt            DateTime?
  deletedBy            String?   @db.Uuid

  contacts           crm_Contacts[]
  leads              crm_Leads[]
  converted_targets  crm_Targets[]         @relation("target_converted_account")
  industry_type      crm_Industry_Type?    @relation(fields: [industry], references: [id])
  opportunities      crm_Opportunities[]
  assigned_to_user   Users?                @relation("AccountAssignedTo", fields: [assigned_to], references: [id])
  crm_accounts_tasks crm_Accounts_Tasks[]
  contracts          crm_Contracts[]
  documents          DocumentsToAccounts[]
  watchers           AccountWatchers[]
  embedding          crm_Embeddings_Accounts?
  emails             EmailsToAccounts[]
  invoices           Invoices[]

  @@index([assigned_to])
  @@index([industry])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
}

model crm_Leads {
  id String @id @default(uuid()) @db.Uuid
  v  Int    @default(0) @map("__v")

  createdAt         DateTime?          @default(now())
  createdBy         String?            @db.Uuid
  updatedAt         DateTime?          @updatedAt
  updatedBy         String?            @db.Uuid
  firstName         String?
  lastName          String
  company           String?
  jobTitle          String?
  email             String?
  phone             String?
  description       String?
  lead_source_id  String?            @db.Uuid
  lead_status_id  String?            @db.Uuid
  lead_type_id    String?            @db.Uuid
  lead_source     crm_Lead_Sources?  @relation("lead_source_relation", fields: [lead_source_id], references: [id])
  lead_status     crm_Lead_Statuses? @relation("lead_status_relation", fields: [lead_status_id], references: [id])
  lead_type       crm_Lead_Types?    @relation("lead_type_relation", fields: [lead_type_id], references: [id])
  refered_by        String?
  campaign          String?
  assigned_to       String?            @db.Uuid
  assigned_to_user  Users?             @relation("LeadAssignedTo", fields: [assigned_to], references: [id])
  accountsIDs       String?            @db.Uuid
  assigned_accounts crm_Accounts?      @relation(fields: [accountsIDs], references: [id])
  documents         DocumentsToLeads[]
  embedding         crm_Embeddings_Leads?
  deletedAt         DateTime?
  deletedBy         String?   @db.Uuid

  // Roofing: property address from lead intake
  property_address  String?
  property_city     String?
  property_state    String?
  property_zip      String?
  request           String?   // what they're calling about

  // Roofing: conversion tracking
  close_reason      crm_Lead_Close_Reason?
  close_notes       String?
  converted_at      DateTime?
  converted_to_contact  String?   @db.Uuid
  converted_to_property String?   @db.Uuid
  converted_to_job      String?   @db.Uuid

  @@index([assigned_to])
  @@index([accountsIDs])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([lead_source_id])
  @@index([lead_status_id])
  @@index([lead_type_id])
  @@index([createdAt])
  @@index([deletedAt])
  conversations     crm_Conversations[]  @relation("conversation_lead")

  @@index([close_reason])
  @@index([converted_at])
}

enum crm_Lead_Close_Reason {
  CONVERTED
  NOT_INTERESTED
  DEAD
  WRONG_NUMBER
  DUPLICATE
  NO_RESPONSE
}

model crm_Contact_Enrichment {
  id          String                  @id @default(uuid()) @db.Uuid
  contactId   String                  @db.Uuid
  status      crm_Enrichment_Status   @default(PENDING)
  fields      String[]
  result      Json?
  error       String?
  triggeredBy String?                 @db.Uuid
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  contact           crm_Contacts      @relation(fields: [contactId], references: [id])
  triggered_by_user Users?            @relation("enrichment_triggered_by", fields: [triggeredBy], references: [id])

  @@index([contactId])
  @@index([status])
  @@index([createdAt])
  @@index([triggeredBy])
}

model crm_Target_Enrichment {
  id          String                  @id @default(uuid()) @db.Uuid
  targetId    String                  @db.Uuid
  status      crm_Enrichment_Status   @default(PENDING)
  fields      String[]
  result      Json?
  error       String?
  triggeredBy String?                 @db.Uuid
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  target            crm_Targets       @relation(fields: [targetId], references: [id])
  triggered_by_user Users?            @relation("target_enrichment_triggered_by", fields: [triggeredBy], references: [id])

  @@index([targetId])
  @@index([status])
  @@index([createdAt])
  @@index([triggeredBy])
}

model crm_Target_Contact {
  id           String                @id @default(uuid()) @db.Uuid
  targetId     String                @db.Uuid
  contactId    String?               @db.Uuid
  name         String?
  email        String?
  title        String?
  phone        String?
  linkedinUrl  String?
  source       String                @default("manual")
  enrichStatus crm_Enrichment_Status @default(PENDING)
  enrichedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  target   crm_Targets    @relation(fields: [targetId], references: [id], onDelete: Cascade)
  contact  crm_Contacts?  @relation("target_contact_link", fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([targetId, email])
  @@unique([targetId, linkedinUrl])
  @@index([targetId])
  @@index([enrichStatus])
}

enum crm_Enrichment_Status {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum crm_AuditLog_Action {
  created
  updated
  deleted
  restored
  relation_added
  relation_removed
}

model crm_Opportunities {
  id               String                  @id @default(uuid()) @db.Uuid
  v                Int                     @default(0) @map("__v")
  account          String?                 @db.Uuid
  assigned_to      String?                 @db.Uuid
  budget           BigInt                  @default(0)
  campaign         String?                 @db.Uuid
  close_date       DateTime?
  contact          String?                 @db.Uuid
  created_by       String?                 @db.Uuid
  createdBy        String?                 @db.Uuid
  created_on       DateTime?               @default(now())
  createdAt        DateTime                @default(now())
  last_activity    DateTime?
  updatedAt        DateTime?               @updatedAt
  updatedBy        String?                 @db.Uuid
  last_activity_by String?                 @db.Uuid
  currency         String?
  description      String?
  expected_revenue BigInt                  @default(0)
  name             String?
  next_step        String?
  sales_stage      String?                 @db.Uuid
  type             String?                 @db.Uuid
  status           crm_Opportunity_Status? @default(ACTIVE)

  // Roofing: job identity
  job_number        String?
  property_id       String?                 @db.Uuid
  payor_type        crm_Payor_Type?
  pipeline          String?
  high_level_stage  String?
  territory         String?
  project_type      String?                 // Roof Replacement, Roof Repair, etc.
  property_type     String?                 // Residential, Commercial
  roof_type         String?

  // Roofing: insurance
  insurance_company       String?
  claim_number            String?
  policy_number           String?
  date_of_loss            DateTime?
  adjuster_id             String?           @db.Uuid
  acv_deposit             Decimal?          @db.Decimal(12, 2)
  deductible              Decimal?          @db.Decimal(12, 2)
  supplement_amount       Decimal?          @db.Decimal(12, 2)
  supplementing           String?
  date_claim_submitted    DateTime?
  date_claim_approved     DateTime?
  date_depreciation_released DateTime?

  // Roofing: financials
  estimated_total         Decimal?          @db.Decimal(12, 2)
  budgeted_amount         Decimal?          @db.Decimal(12, 2)
  budgeted_labor          Decimal?          @db.Decimal(12, 2)
  budgeted_materials      Decimal?          @db.Decimal(12, 2)
  total_expenses          Decimal?          @db.Decimal(12, 2)
  payments_received       Decimal?          @db.Decimal(12, 2)
  gross_profit            Decimal?          @db.Decimal(12, 2)
  net_profit              Decimal?          @db.Decimal(12, 2)
  overhead                Decimal?          @db.Decimal(12, 2)
  overhead_percentage     Decimal?          @db.Decimal(5, 2)
  gross_profit_margin     Decimal?          @db.Decimal(5, 2)
  commission_percentage   Decimal?          @db.Decimal(5, 2)
  commission              Decimal?          @db.Decimal(12, 2)
  commission_tier         String?

  // Roofing: key dates
  date_contract_signed    DateTime?
  date_inspected          DateTime?
  date_work_in_progress   DateTime?
  date_completed          DateTime?
  date_revenue_recognized DateTime?
  date_closed             DateTime?
  follow_up_date          DateTime?
  forecasted_build_date   DateTime?

  // Roofing: lost deal
  lost_deal_reason        String?
  lost_deal_notes         String?
  date_lost               DateTime?

  // Roofing: production
  superintendent_id       String?           @db.Uuid

  // Roofing: integrations
  companycam_url          String?
  companycam_id           String?

  // Roofing: lead source
  primary_lead_source     String?
  secondary_lead_source   String?

  assigned_type        crm_Opportunities_Type?         @relation(fields: [type], references: [id])
  assigned_sales_stage crm_Opportunities_Sales_Stages? @relation("assinged_sales_stage", fields: [sales_stage], references: [id])
  assigned_to_user     Users?                          @relation("assigned_to_user_relation", fields: [assigned_to], references: [id])
  created_by_user      Users?                          @relation("created_by_user_relation", fields: [created_by], references: [id])
  assigned_account     crm_Accounts?                   @relation(fields: [account], references: [id])
  assigned_campaings   crm_campaigns?                  @relation(fields: [campaign], references: [id])
  assigned_property    crm_Properties?                 @relation(fields: [property_id], references: [id])
  adjuster             crm_Contacts?                   @relation("job_adjuster", fields: [adjuster_id], references: [id])
  superintendent       Users?                          @relation("job_superintendent", fields: [superintendent_id], references: [id])
  documents            DocumentsToOpportunities[]
  contacts             ContactsToOpportunities[]
  embedding            crm_Embeddings_Opportunities?
  payments             crm_Payments[]
  stage_transitions    crm_Stage_Transitions[]
  appointments         crm_Appointments[]
  job_tasks            crm_Job_Tasks[]
  purchase_orders      crm_Purchase_Orders[]
  bills                crm_Bills[]
  expenses             crm_Expenses[]
  vendor_credits       crm_Vendor_Credits[]
  estimates            crm_Estimates[]
  invoices_crm         crm_Invoices[]
  credit_notes         crm_Credit_Notes[]
  customer_payments    crm_Customer_Payments[]
  insurance_claims     crm_Insurance_Claims[]
  job_documents        crm_Job_Documents[]
  deletedAt            DateTime?
  deletedBy            String?   @db.Uuid

  @@index([account])
  @@index([assigned_to])
  @@index([campaign])
  @@index([contact])
  @@index([created_by])
  @@index([sales_stage])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([close_date])
  @@index([status, sales_stage])
  @@index([deletedAt])
  @@index([property_id])
  @@index([payor_type])
  @@index([job_number])
  @@index([territory])
  @@index([date_contract_signed])
  @@index([date_inspected])
  @@index([date_completed])
  @@index([follow_up_date])
  @@index([superintendent_id])
}

enum crm_Payor_Type {
  INSURANCE
  CASH_RETAIL
}

enum crm_Opportunity_Status {
  ACTIVE
  INACTIVE
  PENDING
  CLOSED
}

model crm_campaigns {
  id           String    @id @default(uuid()) @db.Uuid
  v            Int       @map("__v")
  name         String
  description  String?
  status       String?   // draft | scheduled | sending | sent | paused | deleted

  template_id  String?   @db.Uuid
  from_name    String?
  reply_to     String?
  scheduled_at DateTime?
  sent_at      DateTime?
  created_by   String?   @db.Uuid
  created_on   DateTime? @default(now())
  updatedAt    DateTime? @updatedAt

  template         crm_campaign_templates?  @relation("CampaignTemplate", fields: [template_id], references: [id])
  created_by_user  Users?                   @relation("created_campaigns", fields: [created_by], references: [id])
  steps            crm_campaign_steps[]
  target_lists     CampaignToTargetLists[]
  sends            crm_campaign_sends[]
  opportunities    crm_Opportunities[]
}

model crm_campaign_templates {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  subject_default String?
  content_html    String    @db.Text
  content_json    Json
  created_by      String?   @db.Uuid
  created_on      DateTime? @default(now())
  updatedAt       DateTime? @updatedAt

  created_by_user Users?               @relation("created_campaign_templates", fields: [created_by], references: [id])
  campaigns       crm_campaigns[]      @relation("CampaignTemplate")
  steps           crm_campaign_steps[]

  @@index([created_by])
}

model crm_campaign_steps {
  id           String    @id @default(uuid()) @db.Uuid
  campaign_id  String    @db.Uuid
  order        Int
  template_id  String    @db.Uuid
  subject      String
  delay_days   Int       @default(0)
  send_to      String    @default("all")  // "all" | "non_openers"
  scheduled_at DateTime?
  sent_at      DateTime?

  campaign crm_campaigns          @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  template crm_campaign_templates @relation(fields: [template_id], references: [id])
  sends    crm_campaign_sends[]

  @@unique([campaign_id, order])
  @@index([campaign_id])
  @@index([scheduled_at])
}

model CampaignToTargetLists {
  campaign_id    String @db.Uuid
  target_list_id String @db.Uuid

  campaign    crm_campaigns   @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  target_list crm_TargetLists @relation(fields: [target_list_id], references: [id], onDelete: Cascade)

  @@id([campaign_id, target_list_id])
}

model crm_campaign_sends {
  id                String    @id @default(uuid()) @db.Uuid
  campaign_id       String    @db.Uuid
  step_id           String    @db.Uuid
  target_id         String    @db.Uuid
  email             String
  status            String    @default("queued")  // queued | sent | delivered | bounced | failed
  resend_message_id String?
  unsubscribe_token String    @unique @default(uuid())
  opened_at         DateTime?
  clicked_at        DateTime?
  unsubscribed_at   DateTime?
  error_message     String?
  sent_at           DateTime?

  campaign crm_campaigns      @relation(fields: [campaign_id], references: [id])  // no Cascade — campaigns use soft delete
  step     crm_campaign_steps @relation(fields: [step_id], references: [id])
  target   crm_Targets        @relation(fields: [target_id], references: [id])

  @@unique([step_id, target_id])
  @@index([campaign_id])
  @@index([step_id, target_id])
  @@index([resend_message_id])
  @@index([status])
  @@index([unsubscribe_token])
}

model crm_Opportunities_Sales_Stages {
  id                                 String              @id @default(uuid()) @db.Uuid
  v                                  Int                 @map("__v")
  name                               String
  probability                        BigInt?
  order                              BigInt?
  assigned_opportunities_sales_stage crm_Opportunities[] @relation("assinged_sales_stage")

  // Roofing: pipeline configuration
  blueprint           String?           // which blueprint: prospect_assignment, inspection, follow_up, pre_production, post_production
  high_level_stage     String?           // grouping: Lead, Inspection, Sales, Pre-Production, Production, Post-Production, Closed
  is_terminal          Boolean           @default(false) // Lost Deal, Closed PIF, Exit
  insurance_only       Boolean           @default(false) // skip for cash customers
  required_fields      Json?             @db.JsonB       // fields required on transition form
  allowed_next_stages  Json?             @db.JsonB       // array of stage IDs that can follow this one

  @@index([blueprint])
  @@index([high_level_stage])
  @@index([is_terminal])
}

model crm_Opportunities_Type {
  id                     String              @id @default(uuid()) @db.Uuid
  v                      Int                 @map("__v")
  name                   String
  order                  BigInt?
  assigned_opportunities crm_Opportunities[]
}

model crm_Contact_Types {
  id       String         @id @default(uuid()) @db.Uuid
  v        Int            @default(0) @map("__v")
  name     String         @unique
  contacts crm_Contacts[]

  @@index([name])
}

model crm_Lead_Sources {
  id    String      @id @default(uuid()) @db.Uuid
  v     Int         @default(0) @map("__v")
  name  String      @unique
  leads crm_Leads[] @relation("lead_source_relation")

  @@index([name])
}

model crm_Lead_Statuses {
  id    String      @id @default(uuid()) @db.Uuid
  v     Int         @default(0) @map("__v")
  name  String      @unique
  leads crm_Leads[] @relation("lead_status_relation")

  @@index([name])
}

model crm_Lead_Types {
  id    String      @id @default(uuid()) @db.Uuid
  v     Int         @default(0) @map("__v")
  name  String      @unique
  leads crm_Leads[] @relation("lead_type_relation")

  @@index([name])
}

model crm_Contacts {
  id               String    @id @default(uuid()) @db.Uuid
  v                Int       @default(0) @map("__v")
  account          String?   @db.Uuid
  assigned_to      String?   @db.Uuid
  birthday         String?
  created_by       String?   @db.Uuid
  createdBy        String?   @db.Uuid
  created_on       DateTime? @default(now())
  cratedAt         DateTime? @default(now())
  last_activity    DateTime? @default(now())
  updatedAt        DateTime? @updatedAt
  updatedBy        String?   @db.Uuid
  last_activity_by String?   @db.Uuid
  description      String?
  email            String?
  personal_email   String?
  first_name       String?
  last_name        String
  office_phone     String?
  mobile_phone     String?
  website          String?
  position         String?
  status           Boolean   @default(true)
  social_twitter   String?
  social_facebook  String?
  social_linkedin  String?
  social_skype     String?
  social_instagram String?
  social_youtube   String?
  social_tiktok    String?
  contact_type_id  String?            @db.Uuid
  contact_type     crm_Contact_Types? @relation(fields: [contact_type_id], references: [id])
  tags             String[]
  notes            String[]

  assigned_to_user  Users?                    @relation("assigned_contacts", fields: [assigned_to], references: [id])
  crate_by_user     Users?                    @relation("created_contacts", fields: [created_by], references: [id])
  accountsIDs       String?                   @db.Uuid
  assigned_accounts crm_Accounts?             @relation(fields: [accountsIDs], references: [id])
  opportunities     ContactsToOpportunities[]
  documents         DocumentsToContacts[]
  embedding         crm_Embeddings_Contacts?
  emails            EmailsToContacts[]
  enrichments           crm_Contact_Enrichment[]
  converted_targets     crm_Targets[]            @relation("target_converted_contact")
  target_contact_links  crm_Target_Contact[]     @relation("target_contact_link")
  adjuster_jobs         crm_Opportunities[]      @relation("job_adjuster")
  adjuster_claims       crm_Insurance_Claims[]   @relation("claim_adjuster")
  owned_properties      crm_Properties[]         @relation("property_owner")
  conversations         crm_Conversations[]      @relation("conversation_contact")
  deletedAt             DateTime?
  deletedBy             String?   @db.Uuid

  @@index([assigned_to])
  @@index([created_by])
  @@index([accountsIDs])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@index([contact_type_id])
  @@index([cratedAt])
  @@index([last_activity])
  @@index([deletedAt])
}

model crm_Contracts {
  id                  String               @id @default(uuid()) @db.Uuid
  v                   Int                  @map("__v")
  title               String
  value               Int
  startDate           DateTime?            @default(now())
  endDate             DateTime?
  renewalReminderDate DateTime?
  customerSignedDate  DateTime?
  companySignedDate   DateTime?
  description         String?
  account             String?              @db.Uuid
  assigned_to         String?              @db.Uuid
  createdAt           DateTime?            @default(now())
  createdBy           String?              @db.Uuid
  updatedAt           DateTime?            @updatedAt
  updatedBy           String?              @db.Uuid
  status              crm_Contracts_Status @default(NOTSTARTED)
  type                String?
  deletedAt           DateTime?
  deletedBy           String?   @db.Uuid

  assigned_account crm_Accounts? @relation(fields: [account], references: [id])
  assigned_to_user Users?        @relation(fields: [assigned_to], references: [id])

  @@index([account])
  @@index([assigned_to])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@index([startDate, endDate])
  @@index([deletedAt])
}

enum crm_Contracts_Status {
  NOTSTARTED
  INPROGRESS
  SIGNED
}

enum crm_Activity_Type {
  call
  meeting
  note
  email
}

enum crm_Activity_Status {
  scheduled
  completed
  cancelled
}

model crm_Activities {
  id          String               @id @default(uuid()) @db.Uuid
  type        crm_Activity_Type
  title       String
  description String?
  date        DateTime
  duration    Int?
  outcome     String?
  status      crm_Activity_Status  @default(scheduled)
  metadata    Json?                @db.JsonB

  // Call disposition (call type only — required before conversation can close)
  disposition     crm_Call_Disposition?
  dispositionNote String?
  dispositionAt   DateTime?
  dispositionBy   String?              @db.Uuid

  createdBy   String?              @db.Uuid
  updatedBy   String?              @db.Uuid
  createdAt   DateTime             @default(now())
  updatedAt   DateTime?            @updatedAt

  created_by_user Users?              @relation("activity_created_by", fields: [createdBy], references: [id])
  updated_by_user Users?              @relation("activity_updated_by", fields: [updatedBy], references: [id])
  disposition_by_user Users?          @relation("activity_disposition_by", fields: [dispositionBy], references: [id])
  links       crm_ActivityLinks[]

  @@index([date])
  @@index([type])
  @@index([status])
  @@index([disposition])
  @@index([createdBy])
  @@index([createdAt])
}

model crm_ActivityLinks {
  id         String          @id @default(uuid()) @db.Uuid
  activityId String          @db.Uuid
  entityType String
  entityId   String          @db.Uuid

  activity crm_Activities @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([entityType, entityId, activityId])
}

// ── Conversations ──────────────────────────────────────────

enum crm_Conversation_Status {
  open
  closed
}

enum crm_Call_Disposition {
  booked
  not_interested
  wrong_number
  spam
  existing_customer
  no_response
}

model crm_Conversations {
  id              String                    @id @default(uuid()) @db.Uuid
  phoneNumber     String?
  subject         String?
  status          crm_Conversation_Status   @default(open)

  contactId       String?   @db.Uuid
  leadId          String?   @db.Uuid

  // Twilio Conversations API
  twilioConversationSid  String?  @unique  // CH... SID linking to Twilio Conversation

  // Twilio call fields (populated for phone channel)
  twilioCallSid       String?   @unique
  twilioCallStatus    String?   // ringing, in-progress, completed, no-answer, busy, failed
  twilioRecordingUrl  String?
  callDirection       String?   // inbound, outbound
  callDuration        Int?      // seconds

  // Tracking number that was called (for inbound)
  trackingNumberId    String?   @db.Uuid
  trackingNumber      crm_Tracking_Numbers? @relation("conversation_tracking", fields: [trackingNumberId], references: [id])

  lastActivityAt  DateTime  @default(now())
  createdBy       String?   @db.Uuid
  updatedBy       String?   @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
  deletedAt       DateTime?
  deletedBy       String?   @db.Uuid

  contact         crm_Contacts?  @relation("conversation_contact", fields: [contactId], references: [id])
  lead            crm_Leads?     @relation("conversation_lead", fields: [leadId], references: [id])
  created_by_user Users?         @relation("conversation_created_by", fields: [createdBy], references: [id])
  updated_by_user Users?         @relation("conversation_updated_by", fields: [updatedBy], references: [id])
  messages        crm_Messages[] @relation("conversation_messages")

  @@index([phoneNumber])
  @@index([contactId])
  @@index([leadId])
  @@index([lastActivityAt])
  @@index([status])
  @@index([deletedAt])
  @@index([twilioCallSid])
  @@index([twilioConversationSid])
  @@index([trackingNumberId])
}

// Individual SMS/chat messages within a conversation
model crm_Messages {
  id              String    @id @default(uuid()) @db.Uuid
  conversationId  String    @db.Uuid
  direction       String    // inbound, outbound
  body            String
  mediaUrls       String[]  // MMS attachments

  // Twilio SMS fields
  twilioMessageSid  String?   @unique
  twilioStatus      String?   // queued, sent, delivered, failed, received
  twilioFrom        String?   // the Twilio number used (inbound: number they texted; outbound: number we sent from)

  sentBy          String?   @db.Uuid  // user who sent (null for inbound)
  createdAt       DateTime  @default(now())

  conversation    crm_Conversations @relation("conversation_messages", fields: [conversationId], references: [id], onDelete: Cascade)
  sent_by_user    Users?            @relation("message_sent_by", fields: [sentBy], references: [id])

  @@index([conversationId, createdAt])
  @@index([twilioMessageSid])
}

// Maps Twilio phone numbers to marketing sources
model crm_Tracking_Numbers {
  id            String    @id @default(uuid()) @db.Uuid
  phoneNumber   String    @unique   // E.164 format: +17195558000
  friendlyName  String              // "Google Ads — Roof Repair"
  source        String              // marketing channel
  campaign      String?             // specific campaign
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @updatedAt

  conversations crm_Conversations[] @relation("conversation_tracking")

  @@index([phoneNumber])
  @@index([isActive])
}

